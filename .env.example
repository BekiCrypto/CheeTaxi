# ─── CheeTaxi Environment Variables ──────────────────────────────────────────
# Copy to .env and fill in real values. Never commit .env.

# Core
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://cheetaxi:cheetaxi@localhost:5432/cheetaxi

# Cache / Queue (Redis)
REDIS_URL=redis://localhost:6379

# JWT / Auth
JWT_SECRET=replace-with-strong-random-256-bit-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Google Maps
GOOGLE_MAPS_API_KEY=

# OpenStreetMap
OPENSTREETMAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png

# Firebase (Push + Realtime)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Payments — Modular
# Stripe (international cards)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Chapa (Ethiopia)
CHAPA_SECRET_KEY=
# Telebirr (Ethiopia Telecom)
TELEBIRR_API_KEY=
TELEBIRR_SHORT_CODE=

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=cheetaxi-api

# API
API_PORT=4000
API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:3000

# Feature flags
ENABLE_FOOD_DELIVERY=true
ENABLE_PARCEL_DELIVERY=true
ENABLE_INTERCITY=true
